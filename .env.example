# Telegram API (从 https://my.telegram.org 获取)
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash

# Telegram Bot Token (从 @BotFather 获取)
TG_BOT_TOKEN=your_bot_token

# 管理员用户 ID（你自己的 Telegram 数字 ID）
TG_ADMIN_USER_ID=your_user_id

# 数据库（开发用 SQLite，生产用 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///data/tg_manager.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/tg_manager

# LLM API Keys（按需配置，至少配一个）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
